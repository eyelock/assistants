{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "files": {
    "includes": [
      "scripts/**/*.mjs",
      "scripts/**/*.js",
      "**/*.json",
      "**/*.jsonc",
      "!**/node_modules",
      "!**/pnpm-lock.yaml",
      "!**/CHANGELOG.md"
    ]
  }
}
