{
  "$schema": "https://eyelock.github.io/ynh/schema/plugin.schema.json",
  "name": "planner",
  "version": "0.1.0",
  "description": "Architecture and implementation planning persona",
  "default_vendor": "claude",
  "includes": [
    {
      "git": "github.com/eyelock/assistants",
      "path": "skills/dev",
      "pick": ["skills/dev-project", "skills/dev-review"]
    },
    {
      "git": "github.com/eyelock/assistants",
      "path": "skills/infra",
      "pick": ["skills/gh-os-repo"]
    }
  ]
}
