{
  "$schema": "https://eyelock.github.io/ynh/schema/harness.schema.json",
  "name": "termq-dev",
  "version": "0.1.0",
  "description": "Development harness for the TermQ project — Gitflow workflow with Swift/SwiftUI language support.",
  "default_vendor": "claude",
  "allowed_remote_sources": [
    "github.com/eyelock/assistants"
  ],
  "includes": [
    {
      "git": "github.com/eyelock/assistants",
      "path": "plugins/gitflow"
    },
    {
      "git": "github.com/eyelock/assistants",
      "path": "skills/dev",
      "pick": ["skills/dev-quality", "skills/dev-review", "skills/skill-creator", "skills/gh-cli"]
    },
    {
      "git": "github.com/eyelock/assistants",
      "path": "skills/tech",
      "pick": ["skills/swift-lang"]
    }
  ]
}
