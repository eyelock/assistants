{
  "$schema": "https://eyelock.github.io/ynh/schema/plugin.schema.json",
  "name": "ynh-dev",
  "version": "0.1.0",
  "default_vendor": "claude",
  "includes": [
    {
      "git": "github.com/eyelock/assistants",
      "path": "plugins/gitflow"
    },
    {
      "git": "github.com/Jeffallan/claude-skills.git",
      "pick": [
        "skills/golang-pro"
      ]
    },
    {
      "git": "github.com/eyelock/assistants",
      "path": "skills/dev",
      "pick": [
        "skills/dev-quality",
        "skills/dev-review",
        "skills/skill-creator",
        "skills/gh-cli"
      ]
    },
    {
      "git": "github.com/eyelock/assistants",
      "path": "skills/tech",
      "pick": [
        "skills/go-lang"
      ]
    },
    {
      "git": "github.com/eyelock/assistants",
      "path": "skills/pause"
    }
  ]
}
